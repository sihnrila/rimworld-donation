{
  "name": "rimworld-donation-bridge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting --minify",
    "start": "node dist/index.cjs",
    "package:win": "npm run build && npx @yao-pkg/pkg dist/index.cjs --target node18-win-x64 --output ../streamer-app.exe --no-bytecode --public-packages \"*\" --public",
    "test:chzzk": "node scripts/send-test-chzzk.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@yao-pkg/pkg": "^5.16.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "data/**",
      "config/**"
    ]
  }
}
