# 서버 포트 (기본: 33210)
PORT=33210

# 치지직 HMAC-SHA256 Webhook 시크릿
# 치지직 개발자 콘솔에서 발급받은 시크릿 입력
# 미설정 시 dev mode — 검증 skip (테스트용)
CHZZK_WEBHOOK_SECRET=

# event.json 저장 경로 (기본: exe 옆 data/event.json)
# 2PC 구성 시 게임컴 공유 폴더 경로로 변경
# 예) EVENT_FILE_PATH=\\\\게임PC\\RimDonation\\event.json
EVENT_FILE_PATH=

# 이벤트 로그 파일 경로
LOG_FILE_PATH=

# 구성 파일 디렉토리 (기본: exe 옆 config/)
CONFIG_DIR=
